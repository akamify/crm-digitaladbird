# DigitalADbird CRM — Frontend Production Environment
# The API URL points to the backend through Nginx reverse proxy.
# In production, Nginx proxies /api/* to the Node.js backend on port 4000.
# Since Next.js runs on port 3000 behind Nginx, we use relative /api paths.
NEXT_PUBLIC_API_URL=/api
# In production, Socket.IO connects through Nginx to the same domain
# Nginx must proxy /socket.io/* to the backend
NEXT_PUBLIC_WS_URL=
