# Base URL of the backend API (must include /api).
# When set, frontend will call backend directly with this URL.
# When blank, the Next.js rewrite in next.config.js proxies /api/* to BACKEND_URL.
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# WebSocket URL for real-time chat (Socket.IO server)
# In production, this should match the backend URL without /api
NEXT_PUBLIC_WS_URL=http://localhost:4000
