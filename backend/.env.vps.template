# =============================================================
# DigitalADbird CRM — VPS production .env template
# =============================================================
#
# HOW TO USE:
#   1. ON VPS:  ssh root@<vps>;  cd /root/crm-digitaladbird/backend
#   2. Backup current:  cp .env .env.bak-$(date +%s)
#   3. Replace:         nano .env  (paste this template content)
#   4. Fill in EVERY <COPY_FROM_LOCAL> below by reading from your
#      LOCALHOST backend/.env (do NOT paste secrets in chat)
#   5. Restart:         pm2 restart digital-adbird-crm-backend --update-env
#
# NEVER commit this file with real secrets filled in.
# `.env*` is already in .gitignore. Keep it that way.
# =============================================================

# -------- Runtime --------
NODE_ENV=production
PORT=4000
LOG_LEVEL=info
PROCESS_TZ=Asia/Kolkata

# -------- Public URLs (VPS-specific, NOT localhost) --------
APP_URL=https://crm.digitaladbird.com
CORS_ORIGINS=https://crm.digitaladbird.com,https://www.crm.digitaladbird.com

# -------- Database (PostgreSQL on VPS — KEEP CURRENT VALUE on VPS) --------
# DO NOT copy DATABASE_URL from localhost — local uses embedded PG port 5433.
# VPS already has its own Postgres. Keep VPS's existing DATABASE_URL line.
# Just confirm: grep '^DATABASE_URL=' .env.bak-* on VPS and keep that.
DATABASE_URL=<KEEP_VPS_EXISTING_VALUE>
DB_SSL=false
DB_POOL_MAX=20
DB_STATEMENT_TIMEOUT=15000

# -------- JWT (CRITICAL: must match across restarts so sessions survive) --------
# Copy EXACTLY from localhost backend/.env. If you change these, all
# logged-in users will be force-logged-out (their tokens become invalid).
JWT_ACCESS_SECRET=<COPY_FROM_LOCAL>
JWT_REFRESH_SECRET=<COPY_FROM_LOCAL>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# -------- OTP --------
OTP_PROVIDER=console
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# MSG91 (leave blank if not used)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=OTPSMS

# Twilio (leave blank if not used)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Fast2SMS (leave blank if not used)
FAST2SMS_API_KEY=

# -------- Meta (Facebook) Lead Ads --------
META_APP_ID=2283252092484099
META_APP_SECRET=<COPY_FROM_LOCAL>
META_USER_ACCESS_TOKEN=<COPY_FROM_LOCAL>
META_PAGE_ACCESS_TOKEN=<COPY_FROM_LOCAL>
META_PAGE_ID=220342467819979
META_PAGE_NAME=Digital AdBird
META_AD_ACCOUNT_IDS=act_4427126714020065,act_5090581587834677
META_FORM_ID=120234965746240243
META_VERIFY_TOKEN=<COPY_FROM_LOCAL>
META_GRAPH_VERSION=v21.0

# NOTE: Most Meta tokens above expired 2026-05-18 or 2026-06-04.
