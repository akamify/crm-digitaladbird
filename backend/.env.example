# ---------------------------------------------------------------
# DigitalADbird CRM — Backend environment
# Copy to `.env` and fill in real values for production.
# ---------------------------------------------------------------

NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# -------- Database (PostgreSQL / Supabase) --------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/digitaladbird
DB_SSL=false
DB_POOL_MAX=20
DB_STATEMENT_TIMEOUT=15000

# -------- JWT --------
# generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_with_a_64_byte_hex
JWT_REFRESH_SECRET=replace_me_with_another_64_byte_hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# -------- OTP --------
# OTP_PROVIDER ∈ { msg91, twilio, fast2sms, console }
OTP_PROVIDER=console
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# MSG91 (recommended for India)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=OTPSMS

# Twilio (international fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Fast2SMS
FAST2SMS_API_KEY=

# -------- Meta (Facebook) Lead Ads --------
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=replace_me_with_a_random_string
META_GRAPH_VERSION=v19.0

# -------- Lead lock --------
LEAD_LOCK_MINUTES=10

# -------- Rate limit --------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

LOG_LEVEL=debug
